@page
@model IndexModel

@{
    ViewData["Title"] = "Página Inicial";
}

<div class="container">

    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
        <div class="container-fluid py-3">

            <h1 class="display-4 fw-bold">
                Bem-vindo ao WebGinasio
            </h1>

            <p class="lead">
                Sistema de gestão de ginásio desenvolvido em ASP.NET Core Razor Pages.
            </p>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <p class="fs-5">
                    Bem-vindo,
                    <strong>@User.Identity.Name</strong>!
                </p>
            }
            else
            {
                <a asp-page="/Login/Login"
                   class="btn btn-primary btn-lg">
                    Iniciar Sessão
                </a>
            }

        </div>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="row g-4">

            <div class="col-md-4">
                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <h4 class="card-title">
                            👥 Membros
                        </h4>

                        <p class="card-text">
                            Gerir todos os membros do ginásio.
                        </p>

                    </div>

                    <div class="card-footer bg-white border-0">

                        <a asp-page="/Membros/Index"
                           class="btn btn-primary w-100">
                            Abrir
                        </a>

                    </div>

                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <h4 class="card-title">
                            📋 Planos
                        </h4>

                        <p class="card-text">
                            Consultar e gerir planos de treino.
                        </p>

                    </div>

                    <div class="card-footer bg-white border-0">

                        <a asp-page="/Planos/Index"
                           class="btn btn-success w-100">
                            Abrir
                        </a>

                    </div>

                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <h4 class="card-title">
                            🏋️ Aulas
                        </h4>

                        <p class="card-text">
                            Consultar e gerir as aulas disponíveis.
                        </p>

                    </div>

                    <div class="card-footer bg-white border-0">

                        <a asp-page="/Aulas/Index"
                           class="btn btn-warning w-100">
                            Abrir
                        </a>

                    </div>

                </div>
            </div>

        </div>
    }

</div>