@page
@model WebGinasio.Pages.Planos.DeleteModel

@{
    ViewData["Title"] = "Eliminar Plano";
}

<h1 class="mb-4">Eliminar Plano</h1>

@if (Model.MensagemErro != null)
{
    <div class="alert alert-danger">
        @Model.MensagemErro
    </div>
}

<div class="alert alert-warning">
    Tens a certeza de que queres eliminar este plano?
</div>

<div class="card">
    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">
                Nome
            </dt>

            <dd class="col-sm-9">
                @Model.Plano.Nome
            </dd>

            <dt class="col-sm-3">
                Descrição
            </dt>

            <dd class="col-sm-9">
                @if (string.IsNullOrWhiteSpace(Model.Plano.Descricao))
                {
                    <span>Sem descrição</span>
                }
                else
                {
                    @Model.Plano.Descricao
                }
            </dd>

            <dt class="col-sm-3">
                Preço mensal
            </dt>

            <dd class="col-sm-9">
                @Model.Plano.Preco.ToString("0.00") €
            </dd>

            <dt class="col-sm-3">
                Estado
            </dt>

            <dd class="col-sm-9">
                @if (Model.Plano.Ativo)
                {
                    <span class="badge bg-success">
                        Ativo
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        Inativo
                    </span>
                }
            </dd>

        </dl>

        <form method="post">

            <input type="hidden"
                   asp-for="Plano.Id" />

            <button type="submit"
                    class="btn btn-danger">
                Confirmar eliminação
            </button>

            <a asp-page="Index"
               class="btn btn-secondary">
                Cancelar
            </a>

        </form>

    </div>
</div>