@page
@model WebGinasio.Pages.Planos.IndexModel

@{
    ViewData["Title"] = "Planos";
}

<h1 class="mb-4">Planos do Ginásio</h1>

@if (Model.MensagemErro != null)
{
    <div class="alert alert-danger">
        @Model.MensagemErro
    </div>
}

<p>
    <a class="btn btn-success" href="#">
        Novo Plano
    </a>
</p>

<table class="table table-striped table-bordered align-middle">

    <thead class="table-dark">

        <tr>
            <th>Nome</th>
            <th>Descrição</th>
            <th>Preço</th>
            <th>Estado</th>
            <th width="220">Ações</th>
        </tr>

    </thead>

    <tbody>

        @if (Model.Planos.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-center">
                    Não existem planos registados.
                </td>
            </tr>
        }
        else
        {
            @foreach (var plano in Model.Planos)
            {
                <tr>

                    <td>
                        @plano.Nome
                    </td>

                    <td>
                        @plano.Descricao
                    </td>

                    <td>
                        @plano.Preco.ToString("0.00") €
                    </td>

                    <td>

                        @if (plano.Ativo)
                        {
                            <span class="badge bg-success">
                                Ativo
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Inativo
                            </span>
                        }

                    </td>

                    <td>

                        <a class="btn btn-primary btn-sm" href="#">
                            Detalhes
                        </a>

                        <a class="btn btn-warning btn-sm" href="#">
                            Editar
                        </a>

                        <a class="btn btn-danger btn-sm" href="#">
                            Eliminar
                        </a>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>