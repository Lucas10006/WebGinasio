@page
@model WebGinasio.Pages.Aulas.DetailsModel

@{
    ViewData["Title"] = "Detalhes da Aula";
}

<h1 class="mb-4">Detalhes da Aula</h1>

@if (Model.MensagemErro != null)
{
    <div class="alert alert-danger">
        @Model.MensagemErro
    </div>
}
else
{
    <div class="card mb-4">

        <div class="card-header">
            <h4 class="mb-0">
                @Model.Aula.Nome
            </h4>
        </div>

        <div class="card-body">

            <dl class="row">

                <dt class="col-sm-3">
                    Nome
                </dt>

                <dd class="col-sm-9">
                    @Model.Aula.Nome
                </dd>

                <dt class="col-sm-3">
                    Instrutor
                </dt>

                <dd class="col-sm-9">
                    @Model.Aula.Instrutor
                </dd>

                <dt class="col-sm-3">
                    Data e hora
                </dt>

                <dd class="col-sm-9">
                    @Model.Aula.DataHora.ToString("dd/MM/yyyy HH:mm")
                </dd>

                <dt class="col-sm-3">
                    Duração
                </dt>

                <dd class="col-sm-9">
                    @Model.Aula.DuracaoMinutos minutos
                </dd>

                <dt class="col-sm-3">
                    Lotação
                </dt>

                <dd class="col-sm-9">
                    @Model.Aula.Membros.Count / @Model.Aula.LotacaoMaxima

                    @if (Model.Aula.Membros.Count >= Model.Aula.LotacaoMaxima)
                    {
                        <span class="badge bg-danger ms-2">
                            Cheia
                        </span>
                    }
                    else if (Model.Aula.Membros.Count >= Model.Aula.LotacaoMaxima * 0.8)
                    {
                        <span class="badge bg-warning text-dark ms-2">
                            Quase cheia
                        </span>
                    }
                </dd>

                <dt class="col-sm-3">
                    Estado
                </dt>

                <dd class="col-sm-9">
                    @if (Model.Aula.Ativa)
                    {
                        <span class="badge bg-success">
                            Ativa
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Inativa
                        </span>
                    }
                </dd>

            </dl>

        </div>
    </div>

    <h3 class="mb-3">Membros inscritos</h3>

    @if (Model.Aula.Membros.Count == 0)
    {
        <div class="alert alert-info">
            Ainda não existem membros inscritos nesta aula.
        </div>
    }
    else
    {
        <table class="table table-striped table-bordered align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th width="120">Ações</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var membro in Model.Aula.Membros)
                {
                    <tr>

                        <td>
                            @membro.Nome
                        </td>

                        <td>
                            @membro.Email
                        </td>

                        <td>
                            @if (membro.Ativo)
                            {
                                <span class="badge bg-success">
                                    Ativo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Inativo
                                </span>
                            }
                        </td>

                        <td>
                            <form method="post"
                                  asp-page-handler="RemoverMembro"
                                  onsubmit="return confirm('Tens a certeza de que queres remover este membro da aula?');">

                                <input type="hidden"
                                       name="aulaId"
                                       value="@Model.Aula.Id" />

                                <input type="hidden"
                                       name="membroId"
                                       value="@membro.Id" />

                                <button type="submit"
                                        class="btn btn-danger btn-sm">
                                    Remover
                                </button>

                            </form>
                        </td>

                    </tr>
                }

            </tbody>

        </table>
    }

    <a asp-page="Inscrever"
       asp-route-id="@Model.Aula.Id"
       class="btn btn-success">
        Inscrever membro
    </a>

    <a asp-page="Edit"
       asp-route-id="@Model.Aula.Id"
       class="btn btn-warning">
        Editar
    </a>

    <a asp-page="Index"
       class="btn btn-secondary">
        Voltar
    </a>
}