@page
@model WebGinasio.Pages.Aulas.IndexModel

@{
    ViewData["Title"] = "Aulas";
}

<h1 class="mb-4">Aulas do Ginásio</h1>

@if (Model.MensagemErro != null)
{
    <div class="alert alert-danger">
        @Model.MensagemErro
    </div>
}

<p>
    <a class="btn btn-success"
       asp-page="Create">
        Nova Aula
    </a>
</p>

<table class="table table-striped table-bordered align-middle">

    <thead class="table-dark">
        <tr>
            <th>Nome</th>
            <th>Instrutor</th>
            <th>Data e hora</th>
            <th>Duração</th>
            <th>Lotação</th>
            <th>Estado</th>
            <th width="220">Ações</th>
        </tr>
    </thead>

    <tbody>

        @if (Model.Aulas.Count == 0)
        {
            <tr>
                <td colspan="7" class="text-center">
                    Não existem aulas registadas.
                </td>
            </tr>
        }
        else
        {
            @foreach (var aula in Model.Aulas)
            {
                <tr>

                    <td>
                        @aula.Nome
                    </td>

                    <td>
                        @aula.Instrutor
                    </td>

                    <td>
                        @aula.DataHora.ToString("dd/MM/yyyy HH:mm")
                    </td>

                    <td>
                        @aula.DuracaoMinutos minutos
                    </td>

                    <td>
                        @aula.Membros.Count / @aula.LotacaoMaxima

                        @if (aula.Membros.Count >= aula.LotacaoMaxima)
                        {
                            <span class="badge bg-danger ms-1">
                                Cheia
                            </span>
                        }
                        else if (aula.Membros.Count >= aula.LotacaoMaxima * 0.8)
                        {
                            <span class="badge bg-warning text-dark ms-1">
                                Quase cheia
                            </span>
                        }
                    </td>

                    <td>
                        @if (aula.Ativa)
                        {
                            <span class="badge bg-success">
                                Ativa
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Inativa
                            </span>
                        }
                    </td>

                    <td>
                        <a class="btn btn-primary btn-sm"
                           asp-page="Details"
                           asp-route-id="@aula.Id">
                            Detalhes
                        </a>

                        <a class="btn btn-warning btn-sm"
                           asp-page="Edit"
                           asp-route-id="@aula.Id">
                            Editar
                        </a>

                        <a class="btn btn-danger btn-sm"
                           asp-page="Delete"
                           asp-route-id="@aula.Id">
                            Eliminar
                        </a>
                    </td>

                </tr>
            }
        }

    </tbody>

</table>